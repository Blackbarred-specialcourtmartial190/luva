        return '<table class="data">' + tr + '</table>';
      }

      function assetCells(a) {
        return [
          escCell(a.ip_address),
          escCell(a.role),
          escCell((a.eks_components || []).join(', ')),
          escCell(a.mac_address || ''),
          escCell(a.vendor || ''),
          escCell((a.protocols_seen || []).join(', ')),
          escCell((a.open_ports || []).slice(0, 12).join(',') + ((a.open_ports || []).length > 12 ? '…' : '')),
          escCell(a.packet_count),
          escCell(a.bytes_total),
          escCell(a.risk_score),
        ];
      }

      const flowHdr = ['Src', 'Dst', 'Ports', 'Trans', 'ICS', 'Pkts', 'Bytes', 'Writes', 'Exc'];

      const builders = {
        packets: function () {
          return {
            title: 'Packets & capture window',
            html: kvTable([
              ['Total packets (metadata)', meta.total_packets != null ? String(meta.total_packets) : '—'],
              ['Packets (deep survey window)', cw.packets_total != null ? String(cw.packets_total) : '—'],
              ['Packets with IPv4', cw.packets_with_ipv4 != null ? String(cw.packets_with_ipv4) : '—'],
              ['Non-IP frames', cw.non_ip_frames != null ? String(cw.non_ip_frames) : '—'],
              ['Capture span (seconds)', cw.span_seconds != null ? String(cw.span_seconds) : '—'],
              ['Avg. packets / second', cw.avg_packets_per_second != null ? String(cw.avg_packets_per_second) : '—'],
              ['First packet (UTC)', cw.first_packet_utc || '—'],
              ['Last packet (UTC)', cw.last_packet_utc || '—'],
            ]),
          };
        },
        unique_hosts: function () {
          const u = deep.uniques || {};
          const ad = deep.addressing || {};
          let html = kvTable([
            ['Unique source IPv4', u.src_ipv4 != null ? String(u.src_ipv4) : '—'],
            ['Unique destination IPv4', u.dst_ipv4 != null ? String(u.dst_ipv4) : '—'],
            ['Displayed sum (src + dst sets)', u.src_ipv4 != null && u.dst_ipv4 != null ? String(u.src_ipv4 + u.dst_ipv4) : '—'],
          ]);
          html += '<p class="drill-section-title">Addressing hits (packets)</p>' + kvTable([
            ['Source private', ad.src_private_hits != null ? String(ad.src_private_hits) : '—'],
            ['Source public', ad.src_public_hits != null ? String(ad.src_public_hits) : '—'],
            ['Destination private', ad.dst_private_hits != null ? String(ad.dst_private_hits) : '—'],
            ['Destination public', ad.dst_public_hits != null ? String(ad.dst_public_hits) : '—'],
          ]);
          return { title: 'Unique hosts & addressing', html: html };
        },
        flows: function () {
          const note = (meta.export_note ? escCell(meta.export_note) : '') +
            (flows.length < (sum.flows_analyzed || 0)
              ? '<br/>Flow list may be capped in this export; counts in summary use the full analysis.'
              : '');
          return {
            title: 'All flows (this export)',
            html: (note ? '<p class="drill-note">' + note + '</p>' : '') +
              tableHtml(flowHdr, flows.map(flowCells), 500),
          };
        },
        ot_protocols: function () {
          const counts = {};
          otProtos.forEach(function (p) { counts[p] = 0; });
          flows.forEach(function (fl) {
            const arr = fl.ics_protocols;
            if (Array.isArray(arr) && arr.length) {
              arr.forEach(function (p) { if (counts[p] !== undefined) counts[p]++; });
            } else if (fl.ics_protocol) {
              String(fl.ics_protocol).split(',').forEach(function (x) {
                const t = x.trim();
                if (counts[t] !== undefined) counts[t]++;
              });
            }
          });
          const rows = otProtos.map(function (p) { return [escCell(p), escCell(counts[p] || 0)]; });
          if (!otProtos.length) {
            return { title: 'OT / ICS protocol labels', html: '<p class="drill-note">No ICS-tagged application protocols inferred in this export.</p>' };
          }
          return {
            title: 'OT / ICS protocol labels',
            html: tableHtml(['Protocol', 'Flows referencing'], rows, 80),
          };
        },
        assets: function () {
          return {
            title: 'Discovered assets',
            html: tableHtml(
              ['IP', 'Role', 'EKS tags', 'MAC', 'Vendor', 'Protocols', 'Ports', 'Pkts', 'Bytes', 'Risk'],
              assets.map(assetCells),
              500,
            ),
          };
        },
        ot_assets: function () {
          if (!otAssets.length) {
            return { title: 'OT / ICS assets', html: '<p class="drill-note">No hosts matched OT heuristics (ICS ports, parsers, field hints, or inferred roles).</p>' };
          }
          const rows = otAssets.map(function (a) {
            return [
              escCell(a.ip_address),
              escCell(a.role),
              escCell(a.ot_signals_summary || (Array.isArray(a.ot_signals) ? a.ot_signals.join('; ') : '')),
              escCell((a.eks_components || []).join(', ')),
              escCell((a.protocols_seen || []).join(', ')),
              escCell((a.open_ports || []).slice(0, 12).join(',')),
              escCell(a.risk_score),
            ];
          });
          return {
            title: 'OT / ICS assets',
            html: tableHtml(['IP', 'Role', 'OT signals', 'EKS tags', 'Protocols', 'Ports', 'Risk'], rows, 500),
          };
        },
        anomalies: function () {
          if (!anomalies.length) {
            return { title: 'Anomalies', html: '<p class="drill-note">No anomaly events in this report.</p>' };
          }
          const rows = anomalies.map(function (e) {
            return [
              escCell(e.event_id),
              escCell(e.severity),
              escCell(e.category),
              escCell(e.rule_id),
              escCell((e.description || '').slice(0, 400) + ((e.description || '').length > 400 ? '…' : '')),
            ];
          });
          return {
            title: 'Anomalies (all severities)',
            html: tableHtml(['ID', 'Severity', 'Category', 'Rule', 'Description'], rows, 500),
          };
        },
        critical: function () {
          const crit = anomalies.filter(function (e) { return e.severity === 'CRITICAL'; });
          if (!crit.length) {
            return { title: 'Critical anomalies', html: '<p class="drill-note">No CRITICAL-severity anomaly events.</p>' };
          }
          const rows = crit.map(function (e) {
            return [
              escCell(e.event_id),
              escCell(e.category),
              escCell(e.rule_id),
              escCell((e.description || '').slice(0, 500) + ((e.description || '').length > 500 ? '…' : '')),
            ];
          });
          return { title: 'Critical anomalies', html: tableHtml(['ID', 'Category', 'Rule', 'Description'], rows, 200) };
        },
        runtime: function () {
          return {
            title: 'Analysis run',
            html: kvTable([
              ['Wall time (seconds)', meta.duration_seconds != null ? String(meta.duration_seconds) : '—'],
              ['Analysis timestamp (UTC)', meta.analysis_timestamp || '—'],
              ['Tool version', meta.version != null ? String(meta.version) : '—'],
              ['Analysis mode', meta.analysis_mode || '—'],
            ]),
          };
        },
        inputs: function () {
          const files = meta.input_files || [];
          let html = '<p class="drill-section-title">Input files (' + files.length + ')</p>';
          html += files.length
            ? '<ul style="margin:0.35rem 0 0 1.2rem;color:var(--text);font-size:0.85rem;">' +
              files.map(function (f) { return '<li><code style="font-size:0.78rem;">' + escCell(f) + '</code></li>'; }).join('') + '</ul>'
            : '<p class="drill-note">No input paths recorded.</p>';
          html += '<p class="drill-section-title">Evidence integrity (SHA-256)</p>';
          if (!evRowsDrill.length) {
            html += '<p class="drill-note">No per-file hash rows in metadata.</p>';
          } else {
            html += tableHtml(
              ['File', 'Size (bytes)', 'SHA-256'],
              evRowsDrill.map(function (r) {
                return [
                  escCell(r.filename || r.path || ''),
                  escCell(r.size_bytes != null ? String(r.size_bytes) : ''),
                  escCell(r.sha256 || ''),
                ];
              }),
              100,
            );
          }
          return { title: 'Inputs & evidence', html: html };
        },
        flow_bytes: function () {
          const sorted = flows.slice().sort(function (a, b) { return (b.byte_count || 0) - (a.byte_count || 0); });
          const top = sorted.slice(0, 60).map(flowCells);
          return {
            title: 'Flow bytes',
            html: kvTable([
              ['Total bytes (summed on flows)', fs.total_bytes != null ? String(fs.total_bytes) : '—'],
              ['Total packets (summed on flows)', fs.total_packets != null ? String(fs.total_packets) : '—'],
            ]) + '<p class="drill-section-title">Top flows by bytes</p>' +
              tableHtml(flowHdr, top, 60),
          };
        },
        ics_flows: function () {
          const subset = flows.filter(flowIsIcs);
          return {
            title: 'ICS / parser-tagged flows',
            html: '<p class="drill-note">' + subset.length + ' flow(s) with ICS protocol labels in this export.</p>' +
              tableHtml(flowHdr, subset.map(flowCells), 500),
          };
        },
        write_flows: function () {
          const subset = flows.filter(function (fl) { return fl.has_write_operations; });
          return {
            title: 'Flows with write operations',
            html: '<p class="drill-note">' + subset.length + ' flow(s) with industrial write operations observed.</p>' +
              tableHtml(flowHdr, subset.map(flowCells), 500),
          };
        },
        exc_flows: function () {
          const subset = flows.filter(function (fl) { return (fl.exception_count || 0) > 0; });
          return {
            title: 'Flows with protocol exceptions',
            html: '<p class="drill-note">' + subset.length + ' flow(s) with non-zero exception counts.</p>' +
              tableHtml(flowHdr, subset.map(flowCells), 500),
          };
        },
        risk_assets: function () {
          const subset = assets.filter(function (a) { return (a.risk_score || 0) > 0; });
          if (!subset.length) {
            return { title: 'Assets with risk', html: '<p class="drill-note">No assets with risk score &gt; 0.</p>' };
          }
          return {
            title: 'Assets with risk score &gt; 0',
            html: tableHtml(
              ['IP', 'Role', 'EKS tags', 'MAC', 'Vendor', 'Protocols', 'Ports', 'Pkts', 'Bytes', 'Risk'],
              subset.map(assetCells),
              500,
            ),
          };
        },
        eks_tagged: function () {
          const tagged = invHosts.filter(function (h) { return (h.eks_components || []).length > 0; });
          if (!tagged.length) {
            return { title: 'EKS-tagged hosts', html: '<p class="drill-note">No hosts with ≥1 EKS catalog tag.</p>' };
          }
          const rows = tagged.map(function (h) {
            return [
              escCell(h.ip_address),
              escCell(h.role || ''),
              escCell((h.eks_components || []).join(', ')),
              escCell((h.protocols_seen || []).join(', ')),
            ];
          });
          return {
            title: 'Hosts with EKS tags',
            html: tableHtml(['IP', 'Role', 'EKS components', 'Protocols'], rows, 500),
          };
        },
        audit_rows: function () {
          if (!auditFindings.length) {
            return { title: 'Audit workbook', html: '<p class="drill-note">No structured audit findings.</p>' };
          }
          const rows = auditFindings.map(function (f) {
            return [
              escCell(f.finding_id),
              escCell(f.severity),
              escCell(f.category),
              escCell(f.title),
              escCell((f.narrative || '').slice(0, 280) + ((f.narrative || '').length > 280 ? '…' : '')),
            ];
          });
          return {
            title: 'Audit workbook findings',
            html: tableHtml(['ID', 'Severity', 'Category', 'Title', 'Narrative (excerpt)'], rows, 200),
          };
        },
        pattern_flows: function () {
          const mbw = tp.modbus_write_flows || [];
          const s7c = tp.s7_critical_flows || [];
          const itp = tp.it_remote_protocol_flows || [];
          let html = '';
          html += '<p class="drill-section-title">Modbus write flows (' + mbw.length + ')</p>';
          html += mbw.length
            ? tableHtml(
              ['Flow ID', 'Src', 'Dst', 'Ports', 'Write FCs', 'Interpretation', 'Pkts'],
              mbw.map(function (r) {
                return [
                  escCell(r.flow_id),
                  escCell(r.src_ip),
                  escCell(r.dst_ip),
                  escCell(String(r.src_port) + '→' + String(r.dst_port)),
                  escCell((r.write_function_codes || []).join(', ')),
                  escCell(r.interpretation || ''),
                  escCell(r.packet_count),
                ];
              }),
              120,
            )
            : '<p class="drill-note">None.</p>';
          html += '<p class="drill-section-title">S7 critical service hints (' + s7c.length + ')</p>';
          html += s7c.length
            ? tableHtml(
              ['Flow ID', 'Src', 'Dst', 'Ports', 'S7 codes', 'Interpretation', 'Pkts'],
              s7c.map(function (r) {
                return [
                  escCell(r.flow_id),
                  escCell(r.src_ip),
                  escCell(r.dst_ip),
                  escCell(String(r.src_port) + '→' + String(r.dst_port)),
                  escCell((r.s7_service_codes_hex || []).join(', ')),
                  escCell(r.interpretation || ''),
                  escCell(r.packet_count),
                ];
              }),
              120,
            )
            : '<p class="drill-note">None.</p>';
          html += '<p class="drill-section-title">IT-style remote access on OT-relevant paths (' + itp.length + ')</p>';
          html += itp.length
            ? tableHtml(
              ['Flow ID', 'Src', 'Dst', 'Ports', 'Service hint', 'Pkts'],
              itp.map(function (r) {
                return [
                  escCell(r.flow_id),
                  escCell(r.src_ip),
                  escCell(r.dst_ip),
                  escCell(String(r.src_port) + '→' + String(r.dst_port)),
                  escCell(r.service_hint || ''),
                  escCell(r.packet_count),
                ];
              }),
              120,
            )
            : '<p class="drill-note">None.</p>';
          return { title: 'Threat-pattern flow roll-ups', html: html };
        },
        avg_pps: function () {
          return {
            title: 'Average packet rate',
            html: kvTable([
              ['Avg. packets / second', cw.avg_packets_per_second != null ? String(cw.avg_packets_per_second) : '—'],
              ['Capture span (seconds)', cw.span_seconds != null ? String(cw.span_seconds) : '—'],
              ['Packets (survey window)', cw.packets_total != null ? String(cw.packets_total) : '—'],
            ]),
          };
        },
        periodic: function () {
          if (!periodicFlows.length) {
            return { title: 'Periodic flows', html: '<p class="drill-note">No periodic / polling-like flow candidates.</p>' };
          }
          const rows = periodicFlows.map(function (p) {
            return [
              escCell(p.src_ip),
              escCell(p.dst_ip),
              escCell(p.protocol),
              escCell(p.period_seconds),
              escCell(p.cv),
              escCell(p.packet_count),
            ];
          });
          return {
            title: 'Periodic / polling-like flows',
            html: tableHtml(['Src', 'Dst', 'Protocol', 'Period s', 'CV', 'Pkts'], rows, 300),
          };
        },
        graph_nodes: function () {
          const gs = topo.graph_stats || {};
          let html = kvTable([
            ['Nodes', gs.total_nodes != null ? String(gs.total_nodes) : '—'],
            ['Edges', gs.total_edges != null ? String(gs.total_edges) : '—'],
            ['Density', gs.density != null ? String(gs.density) : '—'],
            ['Weakly connected', gs.is_connected != null ? String(gs.is_connected) : '—'],
          ]);
          const nodes = topo.nodes || [];
          if (nodes.length) {
            const nrows = nodes.slice(0, 250).map(function (n) {
              return [
                escCell(n.ip_address),
                escCell(n.device_role || ''),
                escCell((n.ics_protocols || []).join(', ')),
                escCell(n.risk_score),
                escCell(n.zone || ''),
              ];
            });
            html += '<p class="drill-section-title">Topology nodes (up to 250)</p>' +
              tableHtml(['IP', 'Role', 'ICS protocols', 'Risk', 'Zone'], nrows, 250);
          } else {
            html += '<p class="drill-note">No node list in topology export.</p>';
          }
          return { title: 'Topology graph', html: html };
        },
      };

      function showDrill(id) {
        const b = builders[id];
        if (!b) return;
        const out = typeof b === 'function' ? b() : b;
        titleEl.textContent = out.title;
        bodyEl.innerHTML = out.html;
        drillRoot.hidden = false;
        mainEl.hidden = true;
        drillRoot.scrollIntoView({ behavior: 'smooth', block: 'start' });
        backBtn.focus();
      }

      function hideDrill() {
        drillRoot.hidden = true;
        mainEl.hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      backBtn.addEventListener('click', hideDrill);

      kr.querySelectorAll('[data-drill]').forEach(function (card) {
        const id = card.getAttribute('data-drill');
        card.addEventListener('click', function () { showDrill(id); });
        card.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            showDrill(id);
          }
        });
      });
    })();
  })();
  </script>
</body>
</html>
