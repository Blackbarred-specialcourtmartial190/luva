        const capN = cap != null ? cap : 500;
        const slice = rowsCells.slice(0, capN);
        const more = rowsCells.length > capN
          ? '<p class="drill-note">Showing ' + capN + ' of ' + rowsCells.length + ' rows.</p>'
          : '';
        const thead = '<thead><tr>' + headers.map(function (h) { return '<th>' + escCell(h) + '</th>'; }).join('') + '</tr></thead>';
        const tbody = '<tbody>' + slice.map(function (cells) {
          return '<tr>' + cells.map(function (c) { return '<td>' + c + '</td>'; }).join('') + '</tr>';
        }).join('') + '</tbody>';
        return more + '<div class="scroll drill-scroll"><table class="data">' + thead + tbody + '</table></div>';
      }

      function kvTable(rows) {
        const tr = rows.map(function (r) {
          return '<tr><th>' + escCell(r[0]) + '</th><td>' + escCell(r[1]) + '</td></tr>';
