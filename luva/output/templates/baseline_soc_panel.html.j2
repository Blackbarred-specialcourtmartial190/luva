{# Slim embedded SOC widgets: vis-network + comm table + alerts (no duplicate charts vs Executive). #}
{# Styled for Material / Google light theme (matches interactive_report). #}
<style>
  #bl-network-graph {
    width: 100%;
    min-height: min(65vh, 820px);
    height: min(62vh, 800px);
  }
</style>
<div class="text-gray-800">
  <p class="mb-4 text-sm leading-relaxed text-gray-600">
    Interactive graph and edge list derived from this run. <strong>Export JSON</strong> uses the same bundle shape as
    <code class="rounded bg-gray-100 px-1 text-xs text-gray-800">communication_map</code> / SIEM-friendly archives (flows + deep survey signals).
  </p>
  <div id="bl-error-panel" class="mb-4 hidden rounded-lg border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-900" role="alert"></div>
  <div id="bl-loading-overlay" class="hidden py-8 text-center text-sm text-gray-600">Loading…</div>

  <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
    <p id="bl-meta-line" class="font-mono text-xs text-gray-600">—</p>
    <div class="flex flex-wrap items-center gap-2">
      <input id="bl-filter-ip" type="search" placeholder="Filter by IP…"
        class="w-44 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm sm:w-52" />
      <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-700">
        <input id="bl-filter-ics-only" type="checkbox" class="accent-blue-600" /> ICS only
      </label>
      <button id="bl-btn-export" type="button" class="rounded-lg border border-blue-600 bg-white px-3 py-2 text-sm font-medium text-blue-700 shadow-sm hover:bg-blue-50">Export JSON</button>
    </div>
  </div>

  <section class="card-glass mb-6 p-4">
    <div class="mb-3 flex items-center justify-between">
      <h3 class="text-base font-medium text-gray-900">SOC-style alerts (rollup)</h3>
      <span id="bl-alert-count-badge" class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800">0</span>
    </div>
    <div id="bl-alerts-list" class="max-h-56 space-y-2 overflow-y-auto text-sm"></div>
  </section>

  <section class="card-glass mb-6 p-4">
    <h3 class="mb-3 text-base font-medium text-gray-900">Communication graph</h3>
    <div id="bl-network-graph" class="rounded-xl border border-gray-200 bg-gray-50"></div>
    <div class="mt-3 flex flex-wrap gap-3 text-xs text-gray-600">
      <span><span class="mr-1 inline-block h-2 w-2 rounded-full bg-green-600"></span>ICS-related</span>
      <span><span class="mr-1 inline-block h-2 w-2 rounded-full bg-blue-500"></span>Normal</span>
      <span><span class="mr-1 inline-block h-2 w-2 rounded-full bg-orange-500"></span>Suspicious</span>
      <span><span class="mr-1 inline-block h-2 w-2 rounded-full bg-red-600"></span>IT-style</span>
    </div>
  </section>

  <section class="card-glass p-4">
    <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <h3 class="text-base font-medium text-gray-900">Communications (aggregated edges)</h3>
      <input id="bl-table-search" type="search" placeholder="Search table…"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm sm:max-w-xs" />
    </div>
    <div class="overflow-x-auto rounded-xl border border-gray-200">
      <table id="bl-comm-table" class="w-full text-left text-sm">
        <thead class="border-b border-gray-200 bg-gray-100 text-xs font-medium uppercase text-gray-600">
          <tr>
            <th class="cursor-pointer px-3 py-2 hover:text-blue-700" data-sort="src">Src IP</th>
            <th class="cursor-pointer px-3 py-2 hover:text-blue-700" data-sort="dst">Dst IP</th>
            <th class="cursor-pointer px-3 py-2 hover:text-blue-700" data-sort="packets">Packets</th>
            <th class="cursor-pointer px-3 py-2 hover:text-blue-700" data-sort="bytes">Bytes</th>
          </tr>
        </thead>
        <tbody id="bl-comm-tbody"></tbody>
      </table>
    </div>
    <p id="bl-table-info" class="mt-2 text-xs text-gray-500"></p>
  </section>
</div>
